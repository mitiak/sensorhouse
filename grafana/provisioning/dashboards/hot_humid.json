        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": {"mode": "fixed", "fixedColor": "red"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Sensors Reporting Extreme Heat",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 13},
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "PDEE91DDB90597936"},
      "targets": [
        {
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "PDEE91DDB90597936"},
          "rawSql": "SELECT uniq(sensor_id) AS sensors FROM sensors.readings WHERE temperature >= 35 AND temperature <= 60",
          "refId": "A",
