{
  "title": "Hot Days",
  "uid": "sensorhouse-hot-humid",
  "description": "Extreme temperature events — days with readings above 35°C (BMP180 dataset; no humidity data).",
  "refresh": "10m",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["sensorhouse", "weather"],
  "time": {"from": "2019-01-01T00:00:00Z", "to": "2020-01-01T00:00:00Z"},
  "timepicker": {},
